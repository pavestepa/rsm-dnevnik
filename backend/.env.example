PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rsm_dnevnik

NODE_ENV=development

# Auth
USERS_FILE_PATH=../users.json
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Rate limiting for auth endpoints
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=10

# CORS (comma-separated origins, production only)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=rsm:

# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Swagger
SWAGGER_ENABLED=true

# S3-compatible storage (MinIO in local dev — started via pnpm infra:up)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rsm-dnevnik
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRES_IN=3600
S3_ENSURE_BUCKET_ON_STARTUP=true
# Public URL for avatar images (use LAN IP for physical devices, e.g. http://192.168.1.10:9000)
S3_PUBLIC_BASE_URL=http://localhost:9000
