EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_WS_URL=http://localhost:3000
EXPO_PUBLIC_DEFAULT_LOCALE=ru

# For physical devices use your machine LAN IP, e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# EXPO_PUBLIC_WS_URL=http://192.168.1.10:3000
#
# Backend must use the same host for S3 (port 9000):
# S3_PUBLIC_BASE_URL=http://192.168.1.10:9000
